---
const skillGroups = [
  {
    category: "backend",
    labelKey: "skills.backend",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
    skills: ["Node.js", "Express", "NestJS", "REST APIs", "GraphQL", "TypeScript", "Microservices"],
  },
  {
    category: "frontend",
    labelKey: "skills.frontend",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    skills: ["React", "Vue.js", "Angular", "Next.js", "Tailwind CSS", "Quasar"],
  },
  {
    category: "databases",
    labelKey: "skills.databases",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    skills: ["MongoDB", "PostgreSQL", "SQL Server", "MySQL", "MariaDB"],
  },
  {
    category: "cloud",
    labelKey: "skills.cloud",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>`,
    skills: ["Azure", "AWS Lambda", "Docker", "Firebase", "Git", "PM2"],
  },
  {
    category: "testing",
    labelKey: "skills.testing",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
    skills: ["Mocha", "Chai", "Jest"],
  },
];
---

<section id="skills" class="skills-section" aria-label="Skills and technologies">
  <div class="section-container">
    <p class="section-label" data-i18n="skills.section_label"></p>
    <h2 class="section-title" data-i18n="skills.section_title"></h2>

    <div class="skills-grid">
      {skillGroups.map((group) => (
        <div class="card skill-card" id={`skills-${group.category}`}>
          <div class="skill-header">
            <span class="skill-icon" set:html={group.icon} />
            <h3 class="skill-title" data-i18n={group.labelKey}></h3>
          </div>
          <ul class="skill-list">
            {group.skills.map((skill) => (
              <li class="skill-item">
                <span class="skill-dot" aria-hidden="true"></span>
                <span class="skill-name mono">{skill}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 6rem 0;
    border-top: 1px solid var(--color-border);
  }

  .skills-grid {
    margin-top: 3rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .skills-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .skill-card {
    padding: 1.5rem;
  }

  .skill-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .skill-icon {
    color: var(--color-accent);
    display: flex;
    align-items: center;
  }

  .skill-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .skill-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .skill-item:hover .skill-dot {
    background-color: var(--color-accent);
  }

  .skill-item:hover .skill-name {
    color: var(--color-text);
  }

  .skill-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-border-hover);
    flex-shrink: 0;
    transition: background-color 0.2s;
  }

  .skill-name {
    font-size: 0.75rem;
    color: var(--color-muted);
    transition: color 0.2s;
  }
</style>
