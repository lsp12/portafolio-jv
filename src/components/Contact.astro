---
---

<section id="contact" class="contact-section" aria-label="Contact">
  <div class="section-container">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="section-label" data-i18n="contact.section_label"></p>
        <h2 class="section-title" data-i18n="contact.section_title"></h2>
        <p class="contact-desc" data-i18n="contact.description"></p>

        <div class="contact-links">
          <a
            href="mailto:jonathankenny852@gmail.com"
            class="contact-link-card card"
            id="contact-email-link"
            aria-label="Send email to Jonathan Vera"
          >
            <span class="contact-link-icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <span class="contact-link-text">
              <span
                class="contact-link-label mono"
                data-i18n="contact.email_label"></span>
              <span class="contact-link-value">jonathankenny852@gmail.com</span>
            </span>
          </a>

          <a
            href="https://github.com/lsp12"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link-card card"
            id="contact-github-link"
            aria-label="Jonathan Vera on GitHub"
          >
            <span class="contact-link-icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                ></path>
              </svg>
            </span>
            <span class="contact-link-text">
              <span
                class="contact-link-label mono"
                data-i18n="contact.github_label"></span>
              <span class="contact-link-value">github.com/lsp12</span>
            </span>
          </a>

          <a
            href="https://linkedin.com/in/jonathanvera-developer-web"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link-card card"
            id="contact-linkedin-link"
            aria-label="Jonathan Vera on LinkedIn"
          >
            <span class="contact-link-icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </span>
            <span class="contact-link-text">
              <span
                class="contact-link-label mono"
                data-i18n="contact.linkedin_label"></span>
              <span class="contact-link-value"
                >linkedin.com/in/jonathanvera-developer-web</span
              >
            </span>
          </a>
        </div>
      </div>

      <form
        id="contact-form"
        class="card contact-form"
        novalidate
        aria-label="Contact form"
      >
        <div class="form-field">
          <label
            for="contact-name"
            class="form-label mono"
            data-i18n="contact.form_name"></label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            autocomplete="name"
            class="form-input"
            data-i18n="contact.form_placeholder_name"
            data-i18n-placeholder="true"
          />
        </div>

        <div class="form-field">
          <label
            for="contact-email"
            class="form-label mono"
            data-i18n="contact.form_email"></label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            autocomplete="email"
            class="form-input"
            data-i18n="contact.form_placeholder_email"
            data-i18n-placeholder="true"
          />
        </div>

        <div class="form-field">
          <label
            for="contact-message"
            class="form-label mono"
            data-i18n="contact.form_message"></label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            class="form-input form-textarea"
            data-i18n="contact.form_placeholder_message"
            data-i18n-placeholder="true"></textarea>
        </div>

        <button
          type="submit"
          class="btn-primary form-submit"
          id="contact-submit-btn"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
          <span data-i18n="contact.form_send"></span>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 6rem 0;
    border-top: 1px solid var(--color-border);
  }

  .contact-grid {
    display: grid;
    gap: 4rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-desc {
    margin-top: 1rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .contact-links {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-link-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .contact-link-card:hover .contact-link-icon {
    color: var(--color-accent);
  }

  .contact-link-icon {
    color: var(--color-muted);
    transition: color 0.2s;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .contact-link-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .contact-link-label {
    font-size: 0.7rem;
    color: var(--color-muted);
  }

  .contact-link-value {
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .contact-form {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.75rem;
    color: var(--color-muted);
    font-weight: 500;
  }

  .form-input {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: var(--color-text);
    font-family: "Inter", system-ui, sans-serif;
    outline: none;
    transition: border-color 0.2s ease;
    width: 100%;
    box-sizing: border-box;
  }

  .form-input::placeholder {
    color: var(--color-muted);
  }

  .form-input:focus {
    border-color: var(--color-accent);
  }

  .form-textarea {
    resize: none;
    min-height: 140px;
  }

  .form-submit {
    justify-content: center;
    width: 100%;
  }
</style>

<script>
  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const btn = document.getElementById("contact-submit-btn");
    if (btn) {
      btn.innerHTML = "✓ Sent!";
      setTimeout(() => {
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg><span data-i18n="contact.form_send"></span>`;
      }, 3000);
    }
  });
</script>
