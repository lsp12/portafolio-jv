---
const projects = [
  {
    id: "enterprise-api",
    titleKey: "projects.project_1_title",
    descKey: "projects.project_1_desc",
    bulletKeys: [
      "projects.project_1_h1",
      "projects.project_1_h2",
      "projects.project_1_h3",
      "projects.project_1_h4",
    ],
    tags: ["Node.js", "Express", "PostgreSQL", "JWT", "Swagger"],
    featured: true,
    githubUrl: "https://github.com/lsp12",
  },
  {
    id: "bi-dashboard",
    titleKey: "projects.project_2_title",
    descKey: "projects.project_2_desc",
    bulletKeys: [
      "projects.project_2_h1",
      "projects.project_2_h2",
      "projects.project_2_h3",
      "projects.project_2_h4",
    ],
    tags: ["React", "Recharts", "Tailwind CSS", "Node.js", "ExcelJS"],
    featured: true,
    githubUrl: "https://github.com/lsp12",
  },
  {
    id: "excel-automation",
    titleKey: "projects.project_3_title",
    descKey: "projects.project_3_desc",
    bulletKeys: [
      "projects.project_3_h1",
      "projects.project_3_h2",
      "projects.project_3_h3",
      "projects.project_3_h4",
    ],
    tags: ["Node.js", "ExcelJS", "Express", "SQL Server", "PM2"],
    featured: true,
    githubUrl: "https://github.com/lsp12",
  },
  {
    id: "admin-system",
    titleKey: "projects.project_4_title",
    descKey: "projects.project_4_desc",
    bulletKeys: [
      "projects.project_4_h1",
      "projects.project_4_h2",
      "projects.project_4_h3",
      "projects.project_4_h4",
    ],
    tags: ["Vue.js", "Node.js", "MongoDB", "Express", "Tailwind CSS"],
    featured: false,
    githubUrl: "https://github.com/lsp12",
  },
];
---

<section id="projects" class="projects-section" aria-label="Featured projects">
  <div class="section-container">
    <p class="section-label" data-i18n="projects.section_label"></p>
    <h2 class="section-title" data-i18n="projects.section_title"></h2>
    <p class="projects-subtitle" data-i18n="projects.subtitle"></p>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class="card project-card" id={`project-${project.id}`}>
          <div class="project-header">
            <div class="project-title-group">
              {project.featured && (
                <span class="project-featured mono">★ featured</span>
              )}
              <h3 class="project-title" data-i18n={project.titleKey}></h3>
            </div>
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="project-github-link"
              aria-label="View project on GitHub"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
            </a>
          </div>

          <p class="project-desc" data-i18n={project.descKey}></p>

          <div class="project-highlights">
            <p class="project-highlights-label mono" data-i18n="projects.highlights_label"></p>
            <ul class="project-bullets">
              {project.bulletKeys.map((bulletKey) => (
                <li class="project-bullet-item">
                  <span class="project-bullet-dot" aria-hidden="true"></span>
                  <span class="mono project-bullet-text" data-i18n={bulletKey}></span>
                </li>
              ))}
            </ul>
          </div>

          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 6rem 0;
    border-top: 1px solid var(--color-border);
  }

  .projects-subtitle {
    margin-top: 1rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 640px;
  }

  .projects-grid {
    margin-top: 3rem;
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .project-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-title-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-featured {
    font-size: 0.7rem;
    color: var(--color-green);
  }

  .project-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .project-github-link {
    color: var(--color-muted);
    padding: 0.375rem;
    flex-shrink: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .project-github-link:hover {
    color: var(--color-text);
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .project-highlights {
    flex: 1;
  }

  .project-highlights-label {
    font-size: 0.7rem;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .project-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-bullet-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .project-bullet-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 6px;
  }

  .project-bullet-text {
    font-size: 0.75rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
</style>
