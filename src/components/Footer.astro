---
---

<footer
  class="border-t border-[var(--color-border)] py-8"
  aria-label="Footer"
>
  <div class="section-container flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="mono text-xs text-[var(--color-muted)]">
      © 2025 Jonathan Vera. <span data-i18n="footer.rights"></span>
    </p>
    <p class="mono text-xs text-[var(--color-muted)] flex items-center gap-1.5">
      <span data-i18n="footer.built"></span>
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
        aria-label="Astro framework"
      >
        Astro
      </a>
      <span data-i18n="footer.and"></span>
      <a
        href="https://tailwindcss.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
        aria-label="Tailwind CSS"
      >
        Tailwind CSS
      </a>
    </p>
  </div>
</footer>
