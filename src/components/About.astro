---
---

<section id="about" class="about-section" aria-label="About me">
  <div class="section-container">
    <div class="about-grid">
      <div class="about-text">
        <p class="section-label" data-i18n="about.section_label"></p>
        <h2 class="section-title" data-i18n="about.section_title"></h2>

        <div class="about-paragraphs">
          <p class="about-p" data-i18n="about.p1"></p>
          <p class="about-p" data-i18n="about.p2"></p>
          <p class="about-p" data-i18n="about.p3"></p>
        </div>

        <div class="about-buttons">
          <a
            href="https://github.com/lsp12"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
            id="about-github-link"
            aria-label="Jonathan Vera on GitHub"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/jonathanvera-developer-web/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
            id="about-linkedin-link"
            aria-label="Jonathan Vera on LinkedIn"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <div class="about-stats">
        <div class="card stat-card" id="stat-experience">
          <span
            class="stat-value accent-gradient-text"
            data-i18n="about.stat_1_value"></span>
          <span class="stat-label" data-i18n="about.stat_1_label"></span>
        </div>
        <div class="card stat-card" id="stat-modules">
          <span
            class="stat-value accent-gradient-text"
            data-i18n="about.stat_2_value"></span>
          <span class="stat-label" data-i18n="about.stat_2_label"></span>
        </div>
        <div class="card stat-card" id="stat-integrations">
          <span
            class="stat-value accent-gradient-text"
            data-i18n="about.stat_3_value"></span>
          <span class="stat-label" data-i18n="about.stat_3_label"></span>
        </div>

        <div class="card focus-card">
          <p class="mono focus-title">areas_of_focus.ts</p>
          <ul class="focus-list">
            {
              [
                "Backend APIs & REST services",
                "Business process automation",
                "ERP & accounting integrations",
                "HR & payroll systems",
                "Data processing pipelines",
              ].map((area) => (
                <li class="focus-item">
                  <span class="focus-bullet" aria-hidden="true">
                    ▸
                  </span>
                  <span class="mono focus-text">{area}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 6rem 0;
    border-top: 1px solid var(--color-border);
  }

  .about-grid {
    display: grid;
    gap: 4rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-paragraphs {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-p {
    color: var(--color-muted);
    line-height: 1.7;
  }

  .about-buttons {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stat-card {
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat-value {
    font-size: 2.25rem;
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .focus-card {
    padding: 1.5rem;
    margin-top: 0.5rem;
  }

  .focus-title {
    font-size: 0.75rem;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .focus-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .focus-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .focus-bullet {
    color: var(--color-green);
    font-size: 0.75rem;
  }

  .focus-text {
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>
