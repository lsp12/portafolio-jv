---
---

<section id="education" class="edu-section" aria-label="Education and languages">
  <div class="section-container">
    <p class="section-label" data-i18n="education.section_label"></p>
    <h2 class="section-title" data-i18n="education.section_title"></h2>

    <div class="edu-grid">
      <div class="card edu-card" id="edu-masters">
        <div class="edu-year-badge mono" data-i18n="education.degree1_year"></div>
        <div class="edu-body">
          <p class="edu-spec mono" data-i18n="education.degree1_spec"></p>
          <h3 class="edu-degree" data-i18n="education.degree1_title"></h3>
          <p class="edu-school" data-i18n="education.degree1_school"></p>
          <p class="edu-desc" data-i18n="education.degree1_desc"></p>
        </div>
      </div>

      <div class="card edu-card" id="edu-engineering">
        <div class="edu-year-badge mono" data-i18n="education.degree2_year"></div>
        <div class="edu-body">
          <h3 class="edu-degree" data-i18n="education.degree2_title"></h3>
          <p class="edu-school" data-i18n="education.degree2_school"></p>
          <p class="edu-desc" data-i18n="education.degree2_desc"></p>
        </div>
      </div>

      <div class="card edu-card edu-lang-card" id="edu-languages">
        <div class="edu-lang-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <div class="edu-body">
          <h3 class="edu-degree" data-i18n="education.languages_label"></h3>
          <ul class="edu-lang-list">
            <li class="edu-lang-item">
              <span class="edu-lang-flag" aria-hidden="true">🇪🇸</span>
              <span class="edu-lang-text" data-i18n="education.lang_es"></span>
            </li>
            <li class="edu-lang-item">
              <span class="edu-lang-flag" aria-hidden="true">🇺🇸</span>
              <span class="edu-lang-text" data-i18n="education.lang_en"></span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .edu-section {
    padding: 6rem 0;
    border-top: 1px solid var(--color-border);
  }

  .edu-grid {
    margin-top: 3rem;
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .edu-grid {
      grid-template-columns: 1fr 1fr;
    }

    .edu-lang-card {
      grid-column: span 2;
      max-width: 400px;
    }
  }

  @media (min-width: 1024px) {
    .edu-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .edu-lang-card {
      grid-column: span 1;
      max-width: unset;
    }
  }

  .edu-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .edu-year-badge {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 0.25rem 0.625rem;
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-green);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 500;
  }

  .edu-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .edu-spec {
    font-size: 0.7rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .edu-degree {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .edu-school {
    font-size: 0.8125rem;
    color: var(--color-accent-hover);
    font-weight: 500;
  }

  .edu-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .edu-lang-card {
    flex-direction: row;
    align-items: flex-start;
  }

  .edu-lang-icon {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .edu-lang-list {
    list-style: none;
    margin: 0.5rem 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .edu-lang-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .edu-lang-flag {
    font-size: 1rem;
    line-height: 1;
  }

  .edu-lang-text {
    font-size: 0.875rem;
    color: var(--color-muted);
  }
</style>
