---
---

<header class="nav-header" aria-label="Site header">
  <div class="section-container">
    <nav class="nav-inner" aria-label="Main navigation">
      <a href="/" class="nav-logo" aria-label="Jonathan Vera — Home">
        <span class="nav-logo-accent">jv</span>.dev
      </a>

      <ul class="nav-links" role="list">
        <li><a href="#about" class="nav-link" data-i18n="nav.about">About</a></li>
        <li><a href="#work-history" class="nav-link" data-i18n="nav.work">Work</a></li>
        <li><a href="#skills" class="nav-link" data-i18n="nav.skills">Skills</a></li>
        <li><a href="#projects" class="nav-link" data-i18n="nav.projects">Projects</a></li>
        <li><a href="#contact" class="nav-link" data-i18n="nav.contact">Contact</a></li>
      </ul>

      <div class="nav-actions">
        <button
          id="lang-toggle"
          class="lang-btn"
          aria-label="Switch language"
        >
          <span id="lang-label">ES</span>
        </button>
        <a href="#contact" class="btn-primary nav-hire-btn" id="nav-contact-btn" data-i18n="nav.hire">Hire me</a>
      </div>

      <div class="nav-mobile-controls">
        <button
          id="lang-toggle-mobile"
          class="lang-btn"
          aria-label="Switch language"
        >
          <span id="lang-label-mobile">ES</span>
        </button>
        <button
          id="mobile-menu-toggle"
          class="hamburger-btn"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
        >
          <span class="hamburger-line" id="burger-top"></span>
          <span class="hamburger-line" id="burger-mid"></span>
          <span class="hamburger-line" id="burger-bot"></span>
        </button>
      </div>
    </nav>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <ul class="mobile-menu-list section-container" role="list">
      <li><a href="#about" class="mobile-nav-link" data-i18n="nav.about">About</a></li>
      <li><a href="#work-history" class="mobile-nav-link" data-i18n="nav.work">Work</a></li>
      <li><a href="#skills" class="mobile-nav-link" data-i18n="nav.skills">Skills</a></li>
      <li><a href="#projects" class="mobile-nav-link" data-i18n="nav.projects">Projects</a></li>
      <li><a href="#contact" class="mobile-nav-link" data-i18n="nav.contact">Contact</a></li>
    </ul>
  </div>
</header>

<style>
  .nav-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 1rem;
  }

  .nav-logo {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .nav-logo:hover {
    color: var(--color-accent-hover);
  }

  .nav-logo-accent {
    color: var(--color-accent);
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-actions {
    display: none;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-mobile-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lang-btn {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--color-border-hover);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .lang-btn:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  .nav-hire-btn {
    font-size: 0.875rem;
    padding: 0.5rem 1rem;
  }

  .hamburger-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-muted);
  }

  .hamburger-btn:hover {
    color: var(--color-text);
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 1px;
    background: currentColor;
    transition: all 0.2s ease;
  }

  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu-list {
    list-style: none;
    margin: 0;
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-nav-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .mobile-nav-link:hover {
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }

    .nav-actions {
      display: flex;
    }

    .nav-mobile-controls {
      display: none;
    }

    .mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  import { translations, type Lang } from "../data/translations";

  const STORAGE_KEY = "preferred_lang";

  function getCurrentLang(): Lang {
    const stored = localStorage.getItem(STORAGE_KEY) as Lang | null;
    return stored === "es" ? "es" : "en";
  }

  function applyTranslations(lang: Lang) {
    const t = translations[lang];
    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n");
      if (!key) return;
      const parts = key.split(".");
      let value: unknown = t;
      for (const part of parts) {
        if (value && typeof value === "object") {
          value = (value as Record<string, unknown>)[part];
        } else {
          value = undefined;
          break;
        }
      }
      if (typeof value === "string") {
        const isPlaceholder = el.getAttribute("data-i18n-placeholder") === "true";
        if (isPlaceholder) {
          (el as HTMLInputElement | HTMLTextAreaElement).placeholder = value;
        } else {
          el.textContent = value;
        }
      }
    });

    const nextLabel = lang === "en" ? "ES" : "EN";
    const langLabel = document.getElementById("lang-label");
    const langLabelMobile = document.getElementById("lang-label-mobile");
    if (langLabel) langLabel.textContent = nextLabel;
    if (langLabelMobile) langLabelMobile.textContent = nextLabel;
    document.documentElement.lang = lang;
    localStorage.setItem(STORAGE_KEY, lang);
  }

  function toggleLang() {
    const next: Lang = getCurrentLang() === "en" ? "es" : "en";
    applyTranslations(next);
  }

  document.getElementById("lang-toggle")?.addEventListener("click", toggleLang);
  document.getElementById("lang-toggle-mobile")?.addEventListener("click", toggleLang);

  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("is-open");
    menu?.classList.toggle("is-open");
    toggle.setAttribute("aria-expanded", String(!isOpen));
    menu?.setAttribute("aria-hidden", String(isOpen));
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.remove("is-open");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });

  applyTranslations(getCurrentLang());
</script>
