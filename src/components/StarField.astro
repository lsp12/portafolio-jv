---
---

<canvas id="starfield-canvas" aria-hidden="true"></canvas>

<style>
  #starfield-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  const canvas = document.getElementById("starfield-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  let width = window.innerWidth;
  let height = window.innerHeight;
  let mouseX = 0;
  let mouseY = 0;
  let scrollY = 0;
  let animFrameId: number;

  canvas.width = width;
  canvas.height = height;

  interface Star {
    x: number;
    y: number;
    z: number;
    size: number;
    brightness: number;
    twinkleSpeed: number;
    twinkleOffset: number;
    layer: number;
  }

  interface ShootingStar {
    x: number;
    y: number;
    vx: number;
    vy: number;
    length: number;
    opacity: number;
    life: number;
    maxLife: number;
  }

  const isMobile = () => window.innerWidth < 768;
  const STAR_COUNT = isMobile() ? 100 : 280;
  const stars: Star[] = [];
  const shootingStars: ShootingStar[] = [];

  function createStar(): Star {
    const layer = Math.random() < 0.6 ? 1 : Math.random() < 0.7 ? 2 : 3;
    const size = layer === 1 ? Math.random() * 0.8 + 0.2 : layer === 2 ? Math.random() * 1.2 + 0.6 : Math.random() * 1.8 + 1.0;
    return {
      x: Math.random() * width,
      y: Math.random() * height,
      z: Math.random(),
      size,
      brightness: Math.random() * 0.5 + 0.5,
      twinkleSpeed: Math.random() * 0.02 + 0.005,
      twinkleOffset: Math.random() * Math.PI * 2,
      layer,
    };
  }

  function spawnShootingStar() {
    const angle = Math.random() * 0.4 + 0.1;
    const speed = Math.random() * 8 + 6;
    shootingStars.push({
      x: Math.random() * width * 0.8,
      y: Math.random() * height * 0.4,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      length: Math.random() * 80 + 60,
      opacity: 1,
      life: 0,
      maxLife: Math.random() * 40 + 30,
    });
  }

  for (let i = 0; i < STAR_COUNT; i++) {
    stars.push(createStar());
  }

  let shootingStarTimer = 0;
  const SHOOTING_STAR_INTERVAL = 200;

  function draw(timestamp: number) {
    ctx.clearRect(0, 0, width, height);

    const mobile = isMobile();
    const parallaxX = mobile ? 0 : (mouseX / width - 0.5) * 12;
    const parallaxY = mobile ? 0 : (mouseY / height - 0.5) * 8;
    const scrollParallax = mobile ? 0 : scrollY * 0.08;

    for (const star of stars) {
      const layerFactor = star.layer * 0.3;
      const px = star.x + parallaxX * layerFactor;
      const py = star.y + parallaxY * layerFactor - scrollParallax * layerFactor;

      const twinkle = Math.sin(timestamp * star.twinkleSpeed + star.twinkleOffset);
      const alpha = star.brightness * (0.7 + twinkle * 0.3);

      const normalizedScroll = Math.min(scrollY / (document.body.scrollHeight - window.innerHeight), 1);
      const scrollFade = star.y / height > 0.5 ? 1 : Math.max(0.1, 1 - normalizedScroll * 0.5);

      ctx.beginPath();
      ctx.arc(px, py, star.size, 0, Math.PI * 2);

      if (star.size > 1.4) {
        const gradient = ctx.createRadialGradient(px, py, 0, px, py, star.size * 3);
        gradient.addColorStop(0, `rgba(200, 220, 255, ${alpha * scrollFade})`);
        gradient.addColorStop(0.4, `rgba(160, 190, 255, ${alpha * scrollFade * 0.3})`);
        gradient.addColorStop(1, `rgba(100, 150, 255, 0)`);
        ctx.fillStyle = gradient;
        ctx.arc(px, py, star.size * 3, 0, Math.PI * 2);
      } else {
        const r = star.layer === 1 ? 210 : star.layer === 2 ? 200 : 180;
        const g = star.layer === 1 ? 225 : star.layer === 2 ? 215 : 200;
        const b = 255;
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha * scrollFade})`;
      }
      ctx.fill();
    }

    if (!isMobile()) {
      shootingStarTimer++;
      if (shootingStarTimer >= SHOOTING_STAR_INTERVAL) {
        spawnShootingStar();
        shootingStarTimer = 0;
      }

      for (let i = shootingStars.length - 1; i >= 0; i--) {
        const s = shootingStars[i];
        s.life++;
        s.x += s.vx;
        s.y += s.vy;
        s.opacity = 1 - s.life / s.maxLife;

        if (s.opacity <= 0 || s.life >= s.maxLife) {
          shootingStars.splice(i, 1);
          continue;
        }

        const tailX = s.x - s.vx * (s.length / (s.vx));
        const tailY = s.y - s.vy * (s.length / (s.vx));

        const grad = ctx.createLinearGradient(tailX, tailY, s.x, s.y);
        grad.addColorStop(0, `rgba(255, 255, 255, 0)`);
        grad.addColorStop(0.7, `rgba(180, 210, 255, ${s.opacity * 0.5})`);
        grad.addColorStop(1, `rgba(255, 255, 255, ${s.opacity})`);

        ctx.beginPath();
        ctx.moveTo(tailX, tailY);
        ctx.lineTo(s.x, s.y);
        ctx.strokeStyle = grad;
        ctx.lineWidth = 1.5;
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(s.x, s.y, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${s.opacity})`;
        ctx.fill();
      }
    }

    animFrameId = requestAnimationFrame(draw);
  }

  animFrameId = requestAnimationFrame(draw);

  window.addEventListener("mousemove", (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });

  window.addEventListener("scroll", () => {
    scrollY = window.scrollY;
  }, { passive: true });

  window.addEventListener("resize", () => {
    cancelAnimationFrame(animFrameId);
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
    const newCount = isMobile() ? 100 : 280;
    stars.length = 0;
    for (let i = 0; i < newCount; i++) {
      stars.push(createStar());
    }
    animFrameId = requestAnimationFrame(draw);
  });
</script>
